{
  "name": "vitronitor-example-server-hono",
  "version": "0.1.0",
  "description": "Reference Hono backend for Vitronitor — implements the contracts in docs/BACKEND_CONTRACTS.md",
  "license": "MIT",
  "private": true,
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently --names hono,caddy \"tsx watch server/index.ts\" \"caddy run --config Caddyfile\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:plain": "tsx watch server/index.ts",
    "start": "NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.988.0",
    "@aws-sdk/s3-request-presigner": "^3.988.0",
    "@hono/node-server": "^2.0.0",
    "@supabase/supabase-js": "^2.95.3",
    "dotenv": "^17.3.1",
    "hono": "^4.12.18",
    "semver": "^7.6.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25",
    "@types/semver": "^7.7.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3"
  }
}
