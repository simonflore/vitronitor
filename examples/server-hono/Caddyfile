# HTTP/2 reverse proxy for local development.
#
# Optional — vitronitor's runtime works fine over HTTP/1.1 against the Vite
# dev server's `/api` proxy. Caddy is here so dev exercises the same HTTP/2
# multiplex semantics you'll get in production (long-lived Supabase Realtime
# WebSocket + concurrent /api/sync requests behind one origin).
#
# Setup (one-time):
#   brew install caddy        # or apt/equivalent
#   caddy trust               # writes a self-signed root cert to your keychain
#
# Usage:
#   npm run dev               # starts vite + hono + caddy concurrently
#   Open https://localhost:3000

{
	admin off
}

localhost:3000 {
	tls internal

	# API + sync endpoints → Hono server
	handle /api/* {
		reverse_proxy localhost:3001 {
			header_up Host {upstream_hostport}
			flush_interval -1
		}
	}

	# Everything else (pages, assets, HMR websocket) → Vite dev server
	handle {
		reverse_proxy localhost:5173 {
			header_up Host {upstream_hostport}
			flush_interval -1
		}
	}
}
