# Reference Hono backend — environment variables.
#
# Copy to .env.local in this directory; tsx + dotenv autoload it.
# Vars marked (shared) must match the parent project's .env.local.

# Server runtime
PORT=3001
NODE_ENV=development

# Supabase (shared with client — same values in parent .env.local)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only: bypasses RLS — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# Electric — provision a source via Electric Cloud (https://electric-sql.com)
# pointing at your Supabase Postgres pooler URL, or self-host Electric.
# ELECTRIC_API_URL defaults to https://api.electric-sql.cloud.
ELECTRIC_API_URL=
ELECTRIC_SOURCE_ID=
ELECTRIC_SOURCE_SECRET=

# Object storage — server signs presigned URLs for OTA downloads
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_RELEASES_BUCKET=
