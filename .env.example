# Vitronitor — environment variables (root, client + publish scripts).
#
# Server-side env vars (SUPABASE_SERVICE_ROLE_KEY, ELECTRIC_SOURCE_*,
# PORT, NODE_ENV) live in examples/server-hono/.env.example. Move them
# into your own backend's env file when you implement one.

# Supabase — public (browser-readable) values used by the client to
# init the Supabase JS SDK and by the reference backend to verify JWTs.
# Project Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Native API base URL — read by lib/api-client.ts when running inside
# capacitor:// or file:// (Capacitor / Electron). On web, leave blank
# (relative paths handled by the dev proxy + production reverse proxy).
VITE_API_BASE_URL=

# Object storage — used by the OTA publish scripts to upload bundles
# and installers. The reference backend (examples/server-hono/) signs
# presigned URLs from these same creds.
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_RELEASES_BUCKET=

# Sentry (optional, client-side error tracking)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Fastlane / iOS code signing — read only by Fastlane and Capacitor
# build tooling. Leave blank until you ship to TestFlight.
APPLE_ID=
APP_IDENTIFIER=
TEAM_ID=
ITC_TEAM_ID=
MATCH_GIT_URL=
MATCH_PASSWORD=
APPLE_API_KEY_ID=
APPLE_API_ISSUER_ID=
APPLE_API_KEY_PATH=
