# Fastlane lanes for iOS releases.
#
# Required env (set in .env.local + load before running):
#   APPLE_ID                   — Apple developer account email
#   APP_IDENTIFIER             — bundle id (com.example.app)
#   TEAM_ID                    — Apple developer team id
#   ITC_TEAM_ID                — App Store Connect team id
#   MATCH_GIT_URL              — private repo holding encrypted certs/profiles
#   MATCH_PASSWORD             — passphrase Match uses to en/decrypt
#   APPLE_API_KEY_ID           — App Store Connect API key (recommended over password auth)
#   APPLE_API_ISSUER_ID
#   APPLE_API_KEY_PATH         — path to the .p8 file
#
# Lanes:
#   bundle exec fastlane ios beta      → build + upload to TestFlight
#   bundle exec fastlane ios release   → build + submit to App Store
#   bundle exec fastlane ios certs     → sync certs via Match (one-time per machine)

default_platform(:ios)

XCODE_PROJECT = 'ios/App/App.xcodeproj'
XCODE_WORKSPACE = 'ios/App/App.xcworkspace'
SCHEME = 'App'

def load_asc_api_key
  return nil unless ENV['APPLE_API_KEY_ID']
  app_store_connect_api_key(
    key_id:      ENV['APPLE_API_KEY_ID'],
    issuer_id:   ENV['APPLE_API_ISSUER_ID'],
    key_filepath: ENV['APPLE_API_KEY_PATH'],
  )
end

def cap_sync
  Dir.chdir('..') do
    sh 'npm run cap:sync'
  end
end

def set_build_number
  build = Time.now.strftime('%Y%m%d%H%M')
  increment_build_number(xcodeproj: XCODE_PROJECT, build_number: build)
end

platform :ios do
  desc 'Sync code signing via Match (run once per machine).'
  lane :certs do
    match(type: 'development', readonly: true)
    match(type: 'appstore', readonly: true)
  end

  desc 'Build the SPA, sync Capacitor, and upload to TestFlight.'
  lane :beta do
    cap_sync
    match(type: 'appstore', readonly: true)
    set_build_number
    build_app(
      workspace: XCODE_WORKSPACE,
      scheme: SCHEME,
      export_method: 'app-store',
      clean: true,
    )
    pilot(
      api_key: load_asc_api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc 'Build, upload, and submit for App Store review.'
  lane :release do
    cap_sync
    match(type: 'appstore', readonly: true)
    set_build_number
    build_app(
      workspace: XCODE_WORKSPACE,
      scheme: SCHEME,
      export_method: 'app-store',
      clean: true,
    )
    deliver(
      api_key: load_asc_api_key,
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
    )
  end
end
