{
  "name": "vitronitor",
  "version": "0.1.0",
  "description": "Cross-platform offline-first React boilerplate (web + iOS + Android + Electron) with TanStack DB sync, an @tanstack/offline-transactions outbox, and self-hosted OTA pipelines",
  "license": "MIT",
  "author": "Vitronitor contributors",
  "homepage": "https://github.com/YOUR_ORG/vitronitor#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/vitronitor.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR_ORG/vitronitor/issues"
  },
  "keywords": [
    "boilerplate",
    "offline-first",
    "vite",
    "react",
    "hono",
    "supabase",
    "tanstack-db",
    "offline-transactions",
    "opfs",
    "wa-sqlite",
    "capacitor",
    "electron",
    "ota",
    "pwa"
  ],
  "private": true,
  "scripts": {
    "prebuild": "node scripts/sync-version.js",
    "dev": "vite",
    "build": "bash scripts/vite-build-prod.sh",
    "build:capacitor": "VITE_TARGET=capacitor bash scripts/vite-build-prod.sh",
    "lint": "eslint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "cap:sync": "npm run build:capacitor && npx cap sync && node scripts/register-capacitor-plugins.js",
    "cap:sync:dev": "vite build --mode capacitor-dev && npx cap sync && node scripts/register-capacitor-plugins.js",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android",
    "cap:publish-bundle": "bash scripts/publish-capacitor-bundle.sh",
    "ios:beta": "bundle exec fastlane ios beta",
    "ios:release": "bundle exec fastlane ios release",
    "electron:build-main": "tsc -p electron/tsconfig.json",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:build-main && NODE_ENV=development electron .\"",
    "electron:build": "npm run build && npm run electron:build-main && node scripts/pre-electron-build.js && electron-builder --config electron-builder.config.cjs",
    "electron:build:mac:dev": "CSC_IDENTITY_AUTO_DISCOVERY=false APPLE_ID= APPLE_APP_SPECIFIC_PASSWORD= npm run electron:build -- --mac --arm64 --publish never",
    "electron:start": "npm run electron:build-main && electron .",
    "electron:publish-shell": "bash scripts/publish-electron-shell.sh mac",
    "electron:publish-bundle": "bash scripts/publish-electron-bundle.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/network": "^8.0.1",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@capacitor-community/sqlite": "^8.1.0",
    "@capgo/capacitor-updater": "^8.45.9",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/browser-db-sqlite-persistence": "^0.1.9",
    "@tanstack/capacitor-db-sqlite-persistence": "^0.1.9",
    "@tanstack/offline-transactions": "^1.0.30",
    "@tanstack/query-db-collection": "^1.0.36",
    "@tanstack/react-db": "^0.1.83",
    "@tanstack/react-query": "^5.100.9",
    "extract-zip": "^2.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.13.1",
    "semver": "^7.6.0",
    "use-debounce": "^10.1.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@capgo/cli": "^7.93.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.1.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.7.0",
    "electron-updater": "^6.3.9",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^8.0.8",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "@tanstack/db": "0.6.5"
  },
  "main": "electron/dist/main/index.js"
}
